# ── Required ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# ⚠️  Replace with actual secret before starting the stack
SEARXNG_SECRET=CHANGE_ME

# ── Optional ────────────────────────────────────────────────
# Brave Search API key — https://api-dashboard.search.brave.com
# Free tier: $5/mo credit (~1000 queries)
BRAVE_API_KEY=

# Redis password (optional) — leave empty for no password
REDIS_PASSWORD=

# fastCRW API key (optional) — if set, all crw API requests must include
#   Authorization: Bearer $CRW_API_KEY
# Generate with: openssl rand -hex 32
# CRW_API_KEY=
